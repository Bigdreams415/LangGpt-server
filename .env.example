# Copy this file to .env and fill in the real values
# cp .env.example .env

# App settings
APP_NAME=LangGpt
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# PostgreSQL configuration
# Create with: psql -U <your_superuser> -d postgres
#   CREATE USER lang_gpt_admin WITH PASSWORD 'your_password';
#   CREATE DATABASE lang_gpt_db OWNER lang_gpt_admin;
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lang_gpt_admin
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=lang_gpt_db

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT configuration
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI configuration
GEMINI_API_KEY=your_gemini_key_here

# Security configuration
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=60
